# Shared identity — loaded in all modes (dev, build, preview)
# Mode-specific overrides go in .env.development / .env.production

# School Identity
VITE_SCHOOL_ID=SCH/29
VITE_BRANCH_ID=BRCH/29

# Website token — authorizes this site to read SCH/29 public content
# Generated: 2026-07-13 | Non-expiring | Stored in school_website_tokens (id=4)
VITE_WEBSITE_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzY2hvb2xfaWQiOiJTQ0gvMjkiLCJ0eXBlIjoid2Vic2l0ZSIsImlhdCI6MTc4Mzk2MDYzOH0.HskrxoUeYuivg0QTgTzDRuCuEFxwJJP6cNtSA7v198o

# Admission access token (optional gate — leave blank for open access)

# External admission URL (optional).
# If set, "Apply Now" opens this URL directly — no branch picker, no rules step.
# Leave blank to use the built-in Elite Core admission flow (branch picker + rules).
# Example: VITE_ADMISSION_URL=https://forms.gle/yourGoogleForm
#          VITE_ADMISSION_URL=https://ourlms.com/admissions/apply
VITE_ADMISSION_URL=

# Branding — pulled from school_setup / school_website_content
VITE_APP_NAME=HAJIYA AMINA IBRAHIM HERITAGE ACADEMY
VITE_SCHOOL_NAME=HAJIYA AMINA IBRAHIM HERITAGE ACADEMY

# =============================================================================
# LOGIN PORTAL URLs
# Leave blank to auto-build from VITE_SCHOOL_SHORT_NAME.elitecore.com.ng
# Set these if the school uses a different LMS or custom domain.
# Examples:
#   VITE_LOGIN_URL_STAFF=https://portal.myschoollms.com/staff-login
#   VITE_LOGIN_URL_PARENT=https://portal.myschoollms.com/parent-login
#   VITE_LOGIN_URL_STUDENT=https://portal.myschoollms.com/student-login
# =============================================================================
VITE_LOGIN_URL_STAFF=
VITE_LOGIN_URL_PARENT=
VITE_LOGIN_URL_STUDENT=
