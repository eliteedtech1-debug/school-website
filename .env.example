# API Configuration
VITE_API_URL=http://localhost:5000/api

# School Identity (set per-deployment)
VITE_SCHOOL_ID=SCH/XX
VITE_BRANCH_ID=BRCH/XX

# Main App (EliteScholar portal) URL — where students/parents log in
VITE_APP_URL=https://app.yourdomain.com

# Admission access token (optional gate — leave blank for open access)
VITE_ADMISSION_TOKEN=

# Database Configuration (for backend)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_cms
DB_USER=root
DB_PASSWORD=your_password

# JWT Configuration (for backend)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Email Configuration (for backend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# File Upload Configuration (for backend)
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760

# Frontend Configuration
VITE_APP_NAME=School Management System
VITE_SCHOOL_NAME=Dr. Kabiru Gwarzo Academy