# =============================================================================
# Shared identity — .env (tracked)
# =============================================================================
# Copy this file to .env and fill in per-school values.
# These vars are loaded in ALL modes (dev, build, preview).
# Mode-specific overrides go in .env.development or .env.production.
# =============================================================================

# School Identity (set per-deployment)
VITE_SCHOOL_ID=SCH/XX
VITE_BRANCH_ID=BRCH/XX

# Website token — JWT authorizing this site to read SCHOOL_ID public content
VITE_WEBSITE_TOKEN=eyJ...

# Admission access token (optional — leave blank for open access)

# Branding
VITE_APP_NAME=School Management System
VITE_SCHOOL_NAME=Your School Name

# =============================================================================
# LOGIN PORTAL URLs (optional)
# =============================================================================
# Leave ALL three blank to auto-build login URLs from VITE_SCHOOL_SHORT_NAME:
#   → https://{short_name}.elitecore.com.ng/login?type={staff|parent|student}
#
# Set individual vars if the school uses a DIFFERENT LMS or custom domain.
# You can mix: set only VITE_LOGIN_URL_STUDENT for a school that uses a
# separate student portal but Elite Core for staff/parents.
#
# Examples:
#   VITE_LOGIN_URL_STAFF=https://staff.ourlms.com/login
#   VITE_LOGIN_URL_PARENT=https://parent.ourlms.com/login
#   VITE_LOGIN_URL_STUDENT=https://student.ourlms.com/login
# =============================================================================
VITE_LOGIN_URL_STAFF=
VITE_LOGIN_URL_PARENT=
VITE_LOGIN_URL_STUDENT=

# =============================================================================
# Mode overrides — create these per environment:
# =============================================================================
# .env.development  — loaded by `npm run dev`   (VITE_API_URL, VITE_APP_URL)
# .env.production   — loaded by `npm run build` (VITE_API_URL, VITE_APP_URL)
# =============================================================================
